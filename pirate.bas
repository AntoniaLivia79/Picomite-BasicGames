2021 IF CP%>0 AND CP%+1+LEN(WW$)>LW% THEN PRINT:CP%=0
2022 IF CP%>0 THEN PRINT " ";:CP%=CP%+1
2023 PRINT WW$;:CP%=CP%+LEN(WW$):WW$="":GOTO 2012
2040 REM PRINT LAST WORD
2041 IF LEN(WW$)=0 THEN RETURN
2042 IF CP%>0 AND CP%+1+LEN(WW$)>LW% THEN PRINT:CP%=0
2043 IF CP%>0 THEN PRINT " ";:CP%=CP%+1
2044 PRINT WW$;:CP%=CP%+LEN(WW$)
