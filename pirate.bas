530 F1=0:IF (SF AND INT(2^LL+.5))<>0 THEN F1=1
531 GOTO 550


REM 9. IS NUMBERED FLAG-BIT CLEAR?
540 F1=0:IF (SF AND INT(2^LL+.5))=0 THEN F1=1
541 GOTO 550


