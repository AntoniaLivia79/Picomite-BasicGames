REM 12. IS OBJ LL NOT CARRIED AND NOT IN ROOM?
440 F1=0:IF IA(LL)<>-1 AND IA(LL)<>R THEN F1=1
441 GOTO 550


REM 2. IS PLAYER IN ROOM WITH OBJECT LL?
450 F1=0:IF IA(LL)=R THEN F1=1
451 GOTO 550


REM 13. IS OBJ LL NOT IN STOREROOM (ROOM 0)?
460 F1=0:IF IA(LL)<>0 THEN F1=1
461 GOTO 550


REM 3. IS PLAYER IN ROOM WITH OBJ LL OR CARRYING IT?
470 F1=0:IF IA(LL)=R OR IA(LL)=-1 THEN F1=1
471 GOTO 550


REM 14. IS OBJ LL IN STOREROOM (ROOM 0)?
480 F1=0:IF IA(LL)=0 THEN F1=1
481 GOTO 550


REM 4. IS PLAYER IN ROOM LL?
490 F1=0:IF R=LL THEN F1=1
491 GOTO 550


REM 5. IS OBJ LL NOT IN CURRENT ROOM?
500 F1=0:IF IA(LL)<>R THEN F1=1
501 GOTO 550


REM 6. IS PLAYER NOT CARRYING OBJ LL?
510 F1=0:IF IA(LL)<>-1 THEN F1=1
511 GOTO 550


REM 7. IS PLAYER NOT IN ROOM LL?
520 F1=0:IF R<>LL THEN F1=1
521 GOTO 550


